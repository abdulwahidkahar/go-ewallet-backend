            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_reference\": \"SIM-VA-{{$timestamp}}\",\n  \"description\": \"confirm top up from postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/wallet/topups/{{topup_reference_id}}/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wallet",
                "topups",
                "{{topup_reference_id}}",
                "confirm"
              ]
