        {
          "name": "create top up user 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.top_up && data.top_up.reference_id) {",
                  "  pm.collectionVariables.set('topup_reference_id', data.top_up.reference_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_user1}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "topup-create-{{$timestamp}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000,\n  \"payment_channel\": \"manual\",\n  \"description\": \"top up via postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/wallet/topups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wallet",
                "topups"
              ]
            }
          },
          "response": []
        },
        {
          "name": "confirm top up user 1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_user1}}"
